# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE CREDENTIALS (Required for database operations)
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL: The URL of your Supabase project
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_KEY: Your Supabase service role key
# (Found in: Settings → API → Project API Keys → service_role key)
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI API KEY (Required for embeddings)
# ─────────────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY: Google Gemini API key for embedding chunks
GEMINI_API_KEY="AIzaSyC..."

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA CONFIGURATION (Optional - local embedding model)
# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA_URL: URL to your Ollama instance (default: localhost:11434)
OLLAMA_URL="http://localhost:11434/api/generate"

# OLLAMA_MODEL: The model to use for local embeddings
OLLAMA_MODEL="qwen2.5:3b"

# ─────────────────────────────────────────────────────────────────────────────
# APP CONFIGURATION (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# APP_URL: The URL where this app is hosted (for callbacks, links)
APP_URL="http://localhost:3333"

# WATCH_DIR: Directory to watch for auto-ingestion of PDFs (default: ./auto_ingest_pdfs)
WATCH_DIR="./auto_ingest_pdfs"
